; Repository npm config: map @freeformation scope to GitHub Packages
; NOTE: Do NOT commit personal tokens into this file. Use repository secrets (PACKAGE_PUBLISH_TOKEN)

@freeformation:registry=https://npm.pkg.github.com/
//npm.pkg.github.com/:_authToken=${PACKAGE_PUBLISH_TOKEN}
always-auth=true

; For local development, add your personal auth token to your user npmrc (~/.npmrc):
; //npm.pkg.github.com/:_authToken=PERSONAL_ACCESS_TOKEN
