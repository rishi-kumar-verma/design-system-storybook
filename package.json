{
  "name": "design-system",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plop/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "storybook": "pnpm --filter storybook run dev"
  },
  "devDependencies": {
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "pnpm": "^8.0.0",
    "turbo": "^2.9.12",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "scheduler": "0.26.0"
  }
}
